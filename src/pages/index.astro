---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm Chris.</h1>
			<p>
				This is where I publish my findings, experiments, and thoughts on
				building products and leading teams. No newsletter to sign up for, no
				gate &mdash; just writing.
			</p>
			<p>
				Start with the <a href="/blog">latest posts</a>, or learn a bit
				<a href="/about">about me</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
